entity CarEntity of AppDbContext {
    id      int pk;
    model   varchar(255);
    year    int;
    brandId int;
    colorId int;
}

class CarCreateRequest {
    id int;
    model string;
    year int;
    brandId int;
    colorId int;
}

class CarUpdateRequest {
    model string;
    year int;
    brandId int;
    colorId int;
}
