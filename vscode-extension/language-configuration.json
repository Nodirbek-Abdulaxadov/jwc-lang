{
  "comments": {
    "lineComment": "//"
  },
  "brackets": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["(", ")"],
    ["[", "]"],
    ["\"", "\""]
  ],
  "onEnterRules": [
    {
      "beforeText": "^\\s*(?:function|route|entity|dbcontext|context|if|while|else|try|catch|middleware)\\b.*\\{[^}]*$",
      "action": {
        "indent": "indent"
      }
    }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*\\{\\s*(//.*)?$",
    "decreaseIndentPattern": "^\\s*\\}"
  },
  "wordPattern": "[A-Za-z_][A-Za-z0-9_]*"
}
